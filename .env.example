# App Store Connect API credentials
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Found in App Store Connect → Users and Access → Integrations → API Keys
ASC_ISSUER_ID=your-issuer-id-here
ASC_KEY_ID=your-key-id-here

# Path to your downloaded .p8 private key file
# Default: ./AuthKey_<KEY_ID>.p8 (same folder as scripts)
# ASC_KEY_PATH=./AuthKey_XXXXXXXXXX.p8

# Found in App Store Connect → Agreements, Tax, and Banking (or Reports)
ASC_VENDOR_NUMBER=your-vendor-number

# Numeric App ID — found in App Store Connect → App Information
ASC_APP_ID=your-app-apple-id

# Report date ranges (auto-defaults to yesterday / last month if not set)
# ASC_DAILY_DATE=2025-06-15
# ASC_MONTHLY_DATE=2025-05

# Optional: paste a pre-generated JWT here if you can't use the .p8 file
# ASC_BEARER_TOKEN=eyJhbGci...
